<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_batch_credit_account_form" model="ir.ui.view">
        <field name="name">ocr.batch.credit.account.form</field>
        <field name="model">ocr.batch.credit.account</field>
        <field name="arch" type="xml">
            <form string="貸方科目一括変更">
                <group>
                    <field name="credit_account_id"/>
                    <field name="scope" widget="radio"/>
                    <field name="client_id" invisible="scope != 'client'"/>
                    <field name="document_ids" invisible="1"/>
                    <field name="preview_count" readonly="1" string="対象明細数"/>
                </group>
                <footer>
                    <button name="action_apply" type="object"
                            string="適用" class="btn-primary"/>
                    <button string="キャンセル" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_batch_credit_account" model="ir.actions.act_window">
        <field name="name">貸方科目一括変更</field>
        <field name="res_model">ocr.batch.credit.account</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
