<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ocr_batch_import_form" model="ir.ui.view">
        <field name="name">ocr.batch.import.form</field>
        <field name="model">ocr.batch.import</field>
        <field name="arch" type="xml">
            <form string="一括インポート">
                <group>
                    <field name="upload_mode" widget="radio"/>
                    <field name="client_id"/>
                    <field name="auto_recognize" string="バックグラウンドで識別を実行"/>
                </group>

                <group invisible="upload_mode != 'multi'">
                    <field name="multi_files" widget="many2many_binary"
                           string="ファイル選択（複数可）"/>
                    <p class="text-muted">
                        JPG、PNG、PDFに対応。Ctrl/Cmdキーを押しながら複数ファイルを選択できます。
                    </p>
                </group>

                <group invisible="upload_mode != 'zip'">
                    <field name="zip_file" filename="zip_filename"/>
                    <field name="zip_filename" invisible="1"/>
                    <p class="text-muted">
                        証憑画像のZIPファイルをアップロードしてください。自動的に展開・インポートされます。
                    </p>
                </group>

                <notebook invisible="upload_mode != 'single'">
                    <page string="個別アップロード">
                        <field name="file_ids">
                            <list editable="bottom">
                                <field name="file_data" filename="filename"/>
                                <field name="filename"/>
                            </list>
                        </field>
                    </page>
                </notebook>

                <footer>
                    <button name="action_import" type="object"
                            string="インポート" class="btn-primary"/>
                    <button string="キャンセル" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_ocr_batch_import" model="ir.actions.act_window">
        <field name="name">一括インポート</field>
        <field name="res_model">ocr.batch.import</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
