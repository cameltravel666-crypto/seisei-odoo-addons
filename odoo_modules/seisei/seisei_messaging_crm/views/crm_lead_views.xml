<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Extend CRM lead form with conversation link -->
    <record id="crm_lead_view_form_messaging" model="ir.ui.view">
        <field name="name">crm.lead.form.messaging</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">
            <!-- Add reply button in header -->
            <xpath expr="//button[@name='action_schedule_meeting']" position="after">
                <button name="action_reply_via_channel"
                        type="object"
                        string="Reply via Channel"
                        class="oe_highlight"
                        invisible="not source_conversation_id"/>
            </xpath>
            <!-- Add conversation stat button -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_conversation"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-comments"
                        invisible="not source_conversation_id">
                    <field name="conversation_message_count" widget="statinfo"
                           string="Messages"/>
                </button>
            </xpath>
            <!-- Add conversation field in extra info -->
            <xpath expr="//group[@name='lead_extra_info']" position="inside">
                <field name="source_conversation_id" readonly="1"/>
            </xpath>
        </field>
    </record>
</odoo>
